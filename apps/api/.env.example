# InsForge backend (server-side). Never expose API_KEY to the browser.
INSFORGE_URL=https://yypxa6by.us-east.insforge.app
INSFORGE_ANON_KEY=replace-with-anon-key
INSFORGE_API_KEY=replace-with-admin-api-key   # ik_... full-access; seed/admin only

PORT=8787
WEB_ORIGIN=http://localhost:3000

# OpenRouter (InsForge AI gateway) — chat/text generation: RAG answers,
# OCR->card structuring, and concept-graph extraction. Server-side only.
OPENROUTER_API_KEY=replace-with-openrouter-api-key   # sk-or-v1-...
# Optional chat-model override. Defaults to deepseek/deepseek-v4-flash.
# OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash

# Cloudflare Workers AI — embeddings only (bge-large -> 1024-dim).
# API token needs the "Workers AI" permission. Account id is on the CF dashboard.
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token

# Sarvam — handwriting extraction: Sarvam Vision OCR + sarvam-30b structuring.
SARVAM_API_KEY=replace-with-sarvam-api-key
# Optional: OCR language (BCP-47, e.g. en-IN, hi-IN, ta-IN). Defaults to en-IN.
SARVAM_OCR_LANGUAGE=en-IN
